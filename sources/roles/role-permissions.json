{
  "schema": "applied-intelligence-role-permissions-v2",
  "principle": "Roles control access and responsibility, not agent identity.",
  "devicePrinciple": "The device should be configured once by an authorized person, then kept simple for the role using it.",
  "clearancePrinciple": "Lead marks it done. Supervisor verifies it. CIS clears it from the dashboard layer.",
  "roleGroups": {
    "operational": [
      "Lead",
      "Supervisor",
      "Maintenance",
      "Auditor"
    ],
    "support": [
      "Engineering",
      "Office Logistics"
    ],
    "continuous_improvement": [
      "Continuous Improvement Staff",
      "Continuous Improvement Manager"
    ],
    "management": [
      "General Manager",
      "Executive Management"
    ]
  },
  "permissionBuckets": [
    "capture",
    "respond",
    "review",
    "coordinate",
    "improvement_governance",
    "manage",
    "oversee",
    "admin_setup",
    "export_data"
  ],
  "roles": {
    "Lead": {
      "description": "Floor-level trusted user focused on fast issue capture.",
      "permissions": [
        "capture"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": false,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": false
      },
      "actions": [
        "create_trace_entry",
        "submit_trace_entry",
        "mark_issue_done"
      ]
    },
    "Supervisor": {
      "description": "Owns floor-level verification, response, and review.",
      "permissions": [
        "capture",
        "respond",
        "review"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": false
      },
      "actions": [
        "create_trace_entry",
        "assign_issue",
        "acknowledge_issue",
        "mark_in_progress",
        "verify_issue_done",
        "move_to_verified_complete"
      ]
    },
    "Maintenance": {
      "description": "Acts on maintenance-owned issues and reports repair completion.",
      "permissions": [
        "respond",
        "review"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": false,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": false
      },
      "actions": [
        "acknowledge_maintenance_issue",
        "update_repair_note",
        "mark_repair_complete"
      ]
    },
    "Auditor": {
      "description": "Focused on verification, compliance, checks, and observation.",
      "permissions": [
        "capture",
        "review"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": false
      },
      "actions": [
        "create_trace_entry",
        "review_trace_history",
        "flag_recurring_issue",
        "add_audit_note"
      ]
    },
    "Engineering": {
      "description": "Technical visibility for part, print, routing, process, and fixture-related issues.",
      "permissions": [
        "review",
        "coordinate"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": false
      },
      "actions": [
        "review_technical_issue",
        "add_engineering_note",
        "support_corrective_action",
        "review_process_signal"
      ]
    },
    "Office Logistics": {
      "description": "Coordinates paperwork, scheduling, labels, travelers, materials, and flow support.",
      "permissions": [
        "review",
        "coordinate"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": false
      },
      "actions": [
        "review_flow_issue",
        "coordinate_follow_up",
        "support_release_control",
        "update_logistics_note"
      ]
    },
    "Continuous Improvement Staff": {
      "description": "Reviews verified completed trace items and governs dashboard clearance.",
      "permissions": [
        "review",
        "improvement_governance"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false,
        "clearTraceFromDashboard": true
      },
      "actions": [
        "review_verified_trace",
        "clear_trace_from_dashboard",
        "retain_trace_history",
        "escalate_to_formal_improvement"
      ]
    },
    "Continuous Improvement Manager": {
      "description": "Owns improvement governance, dashboard clearance, retention, and formal escalation decisions.",
      "permissions": [
        "review",
        "improvement_governance",
        "manage"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": true,
        "managementDashboard": true,
        "spreadsheetExports": true,
        "clearTraceFromDashboard": true
      },
      "actions": [
        "review_verified_trace",
        "clear_trace_from_dashboard",
        "archive_trace_history",
        "escalate_to_formal_improvement",
        "review_repeat_pattern"
      ]
    },
    "General Manager": {
      "description": "Broad operational visibility with cross-department oversight and escalation review.",
      "permissions": [
        "manage",
        "review",
        "coordinate"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": true,
        "managementDashboard": true,
        "spreadsheetExports": true,
        "clearTraceFromDashboard": true
      },
      "actions": [
        "review_cross_department_dashboard",
        "review_escalations",
        "configure_device_role",
        "enable_or_disable_modules",
        "override_clearance_when_necessary"
      ]
    },
    "Executive Management": {
      "description": "Top-level oversight focused on trend review, exports, rollups, and high-level escalation.",
      "permissions": [
        "oversee",
        "manage",
        "admin_setup",
        "export_data"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": true,
        "managementDashboard": true,
        "spreadsheetExports": true,
        "clearTraceFromDashboard": true
      },
      "actions": [
        "view_full_dashboard",
        "export_spreadsheet_data",
        "review_rollup_reporting",
        "manage_permissions",
        "configure_device_role",
        "approve_escalation_path",
        "override_clearance_when_necessary"
      ]
    }
  },
  "clearanceRule": {
    "statement": "Maintenance can complete work, but cannot clear traces. CIS is the normal authority for clearing traces from the dashboard after review. General Manager and Executive Management retain oversight-level override authority.",
    "normalClearRoles": [
      "Continuous Improvement Staff",
      "Continuous Improvement Manager"
    ],
    "oversightClearRoles": [
      "General Manager",
      "Executive Management"
    ],
    "blockedClearRoles": [
      "Lead",
      "Supervisor",
      "Maintenance",
      "Auditor",
      "Engineering",
      "Office Logistics"
    ]
  }
}
