{
  "schema": "applied-intelligence-role-permissions-v1",
  "principle": "Roles control access and responsibility, not agent identity.",
  "devicePrinciple": "The device should be configured once by an authorized person, then kept simple for the role using it.",
  "roleGroups": {
    "operational": [
      "Lead",
      "Supervisor",
      "Auditor"
    ],
    "support": [
      "Engineering",
      "Office Logistics"
    ],
    "management": [
      "General Manager",
      "Executive Management"
    ]
  },
  "permissionBuckets": [
    "capture",
    "respond",
    "review",
    "coordinate",
    "manage",
    "oversee",
    "admin_setup",
    "export_data"
  ],
  "roles": {
    "Lead": {
      "description": "Floor-level trusted user focused on fast issue capture and basic routing.",
      "permissions": [
        "capture"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": false,
        "spreadsheetExports": false
      },
      "actions": [
        "create_trace_entry",
        "batch_import_trace",
        "send_to_connect",
        "view_department_items"
      ]
    },
    "Supervisor": {
      "description": "Owns response, assignment, follow-up, and closure.",
      "permissions": [
        "capture",
        "respond",
        "review"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false
      },
      "actions": [
        "create_trace_entry",
        "batch_import_trace",
        "assign_issue",
        "acknowledge_issue",
        "mark_in_progress",
        "resolve_issue",
        "close_issue"
      ]
    },
    "Auditor": {
      "description": "Focused on verification, compliance, checks, and observation.",
      "permissions": [
        "capture",
        "review"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false
      },
      "actions": [
        "create_trace_entry",
        "review_trace_history",
        "flag_recurring_issue",
        "add_audit_note"
      ]
    },
    "Engineering": {
      "description": "Technical visibility for part, print, routing, process, and fixture-related issues.",
      "permissions": [
        "review",
        "coordinate"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false
      },
      "actions": [
        "review_technical_issue",
        "add_engineering_note",
        "support_corrective_action",
        "review_process_signal"
      ]
    },
    "Office Logistics": {
      "description": "Coordinates paperwork, scheduling, labels, travelers, materials, and flow support.",
      "permissions": [
        "review",
        "coordinate"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": false,
        "lockedSettings": false,
        "managementDashboard": true,
        "spreadsheetExports": false
      },
      "actions": [
        "review_flow_issue",
        "coordinate_follow_up",
        "support_release_control",
        "update_logistics_note"
      ]
    },
    "General Manager": {
      "description": "Broad operational visibility with cross-department oversight and escalation review.",
      "permissions": [
        "manage",
        "review",
        "coordinate"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": true,
        "managementDashboard": true,
        "spreadsheetExports": true
      },
      "actions": [
        "review_cross_department_dashboard",
        "review_escalations",
        "configure_device_role",
        "enable_or_disable_modules"
      ]
    },
    "Executive Management": {
      "description": "Top-level oversight focused on trend review, exports, rollups, and high-level escalation.",
      "permissions": [
        "oversee",
        "manage",
        "admin_setup",
        "export_data"
      ],
      "canAccess": {
        "aiTrace": true,
        "aiConnect": true,
        "aiCis": true,
        "lockedSettings": true,
        "managementDashboard": true,
        "spreadsheetExports": true
      },
      "actions": [
        "view_full_dashboard",
        "export_spreadsheet_data",
        "review_rollup_reporting",
        "manage_permissions",
        "configure_device_role",
        "approve_escalation_path"
      ]
    }
  },
  "closureRule": {
    "statement": "Issues should be cleared through AI-Connect supervisor or management flow, not by deleting trace history.",
    "allowedClearRoles": [
      "Supervisor",
      "General Manager",
      "Executive Management"
    ]
  }
}
